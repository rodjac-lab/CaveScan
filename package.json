{
  "name": "cavescan",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:critical": "vitest run",
    "test:smoke": "bash scripts/run-smoke-tests.sh",
    "test:smoke:headed": "bash scripts/run-smoke-tests.sh --headed",
    "test:e2e:flows": "bash scripts/run-flow-tests.sh",
    "verify": "npm run lint && npm run build && npm run test && npm run test:e2e:flows",
    "verify:full": "npm run lint && npm run build && npm run test && npm run test:smoke && npm run test:e2e:flows && npm run eval:celestin",
    "preview": "vite preview",
    "eval:celestin": "RUN_LLM_EVAL=1 vitest run evals/celestin-eval.test.ts",
    "eval:celestin:report": "node scripts/evaluate-celestin.mjs",
    "scorecard:celestin": "node scripts/scorecard-celestin.mjs",
    "scorecard:celestin:quick": "node scripts/scorecard-celestin.mjs --quick",
    "debug:last": "tail -n 1 .celestin-debug/traces.jsonl 2>/dev/null || echo 'No traces captured yet. Start npm run dev and interact with the app.'",
    "debug:tail": "tail -n 5 .celestin-debug/traces.jsonl 2>/dev/null || echo 'No traces yet.'"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.93.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "react-swipeable": "^7.0.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "supabase": "^2.77.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
